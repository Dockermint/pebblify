# pebblify.env.example
#
# Copy this file to /etc/pebblify/.env and fill in secrets.
# This template must never contain real secrets.
#
# Install with mode 0600, owned by pebblify:pebblify:
#   sudo install -m 0600 -o pebblify -g pebblify systemd/pebblify.env.example /etc/pebblify/.env

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Log verbosity: trace | debug | info | warn | error
PEBBLIFY_LOG_LEVEL=info

# Path to the TOML config file. Overrides the default (./config.toml).
PEBBLIFY_CONFIG_PATH=/etc/pebblify/config.toml

# ---------------------------------------------------------------------------
# API authentication (required when api.authentification_mode = basic_auth)
# ---------------------------------------------------------------------------

PEBBLIFY_BASIC_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Telegram notifications (required when notify.mode = telegram)
# ---------------------------------------------------------------------------

PEBBLIFY_TELEGRAM_BOT_TOKEN=

# ---------------------------------------------------------------------------
# SCP / SSH store
# ---------------------------------------------------------------------------

# Path to the private key file (required when save.scp.authentification_mode = key)
PEBBLIFY_SCP_KEY_PATH=

# SSH password (required when save.scp.authentification_mode = password)
PEBBLIFY_SCP_PASSWORD=

# Path to SSH known_hosts file for SCP backend host verification.
# Checked in order: this env var, /etc/pebblify/known_hosts, ~/.ssh/known_hosts.
# Recommended: copy /etc/ssh/ssh_known_hosts or ssh-keyscan output to /etc/pebblify/known_hosts.
# PEBBLIFY_SCP_KNOWN_HOSTS=/etc/pebblify/known_hosts

# ---------------------------------------------------------------------------
# S3 store (required when save.s3.enable = true)
# ---------------------------------------------------------------------------

PEBBLIFY_S3_SECRET_KEY=
